{
  "manifest_version": 3,
  "name": "Aniworld.to & S.to Autoplay",
  "version": "4.13.6",
  "description": "Autoplay for Aniworld.to and S.to with AniSkip API integration for automatic intro detection, plus lots of functions like manual skip fallback, persistent volume, language memory, and more",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://aniworld.to/*",
    "https://s.to/*",
    "https://serienstream.to/*",
    "http://186.2.175.5/*",
    "https://api.jikan.moe/*",
    "https://api.myanimelist.net/*",
    "https://api.aniskip.com/*",
    "https://api.anime-skip.com/*",
    "*://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://aniworld.to/*",
        "https://s.to/*",
        "https://serienstream.to/*",
        "http://186.2.175.5/*",
        "*://*/*"
      ],
      "js": [
        "lib/keyboard.min.js",
        "lib/notiflix-aio.min.js",
        "src/config.js",
        "src/gm-compat.js",
        "src/content.js"
      ],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/vidmoly-patch.js", "src/click-ad-blocker-inject.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
